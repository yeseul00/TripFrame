# Supabase
# https://app.supabase.com → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Google OAuth
# https://console.cloud.google.com → APIs & Services → Credentials
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=your_web_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your_ios_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your_android_client_id.apps.googleusercontent.com

# ─────────────────────────────────────────────────────────────────
# TASK-075: Supabase Redirect URLs 등록 (수동 작업 필요)
# https://app.supabase.com → Authentication → URL Configuration → Redirect URLs
#
# 등록 필요 URL:
#   http://localhost:8081          (Expo web 개발)
#   http://localhost:8082          (Expo web 대체 포트)
#   tripframe://                   (네이티브 딥링크)
#   exp://localhost:8081           (Expo Go 개발)
#
# 완료 후 Google 로그인 오류 없이 동작 확인
# ─────────────────────────────────────────────────────────────────

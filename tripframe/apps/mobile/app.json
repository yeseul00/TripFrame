{
  "expo": {
    "name": "TripFrame",
    "slug": "tripframe",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "tripframe",
    "updates": {
      "enabled": false
    },
    "plugins": [
      "expo-dev-client",
      "expo-secure-store",
      [
        "expo-file-system",
        {}
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "TripWidget",
              "label": "TripFrame D-day",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "description": "다음 여행 D-day 카운트다운"
            }
          ]
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tripframe.app"
    },
    "android": {
      "package": "com.tripframe.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "19220b85-672f-478e-9966-280e78742de9"
      }
    },
    "owner": "seuldoo"
  }
}
